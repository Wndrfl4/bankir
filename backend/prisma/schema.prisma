generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum TransactionType {
  TRANSFER
  TOP_UP
  BILL_PAYMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id              String        @id @default(uuid())
  username        String        @unique
  email           String        @unique
  passwordHash    String
  role            UserRole      @default(USER)
  twoFactorSecret String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        Account[]
  refreshTokens   RefreshToken[]
  sentTransactions     Transaction[] @relation("sentTransactions")
  receivedTransactions Transaction[] @relation("receivedTransactions")
}

model Account {
  id          String        @id @default(uuid())
  userId      String
  iban        String        @unique
  currency    String        @default("KZT")
  balance     Decimal       @db.Decimal(18, 2)
  isPrimary   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  outgoingTransactions Transaction[] @relation("outgoingAccountTransactions")
  incomingTransactions Transaction[] @relation("incomingAccountTransactions")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                String            @id @default(uuid())
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  amount            Decimal           @db.Decimal(18, 2)
  currency          String            @default("KZT")
  note              String?
  provider          String?
  billCategory      String?
  sourceUserId      String?
  destinationUserId String?
  sourceAccountId   String?
  destinationAccountId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sourceUser        User?             @relation("sentTransactions", fields: [sourceUserId], references: [id])
  destinationUser   User?             @relation("receivedTransactions", fields: [destinationUserId], references: [id])
  sourceAccount     Account?          @relation("outgoingAccountTransactions", fields: [sourceAccountId], references: [id])
  destinationAccount Account?         @relation("incomingAccountTransactions", fields: [destinationAccountId], references: [id])
}
